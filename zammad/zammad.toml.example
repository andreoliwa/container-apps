# zammad.toml — instance-specific migration configuration
# Copy to zammad.toml and fill in your values. This file is gitignored.

# Name of the Zammad group that will own all imported tickets.
# The group is created automatically if it doesn't exist.
import_group = "Redmine Import"

# Base URL of the Redmine instance. Added as the first line of each imported ticket
# so you can navigate back to the original issue. Leave empty to skip.
redmine_url = "https://redmine.example.com"

# Organizations to create in Zammad. All fields except the name are optional.
# domain_assignment = true means Zammad will automatically assign users with matching
# email domains to this organization.
[organizations]
# "Acme Corp"  = { domain = "acme.com", domain_assignment = true }
# "Partner Ltd" = {}

# Login of the Zammad user to use as customer when a Redmine issue's author has no match.
# Must be an existing Zammad user (e.g. the admin account created during setup).
default_customer_login = "admin"

# Optional: name of the Redmine IssueCustomField (list type) to import as native Zammad tags.
# Omit or leave empty to skip tag import from custom fields.
# tags_custom_field = "Tags"

# Customers to create in Zammad. The key is the email address (used as the unique identifier).
# All other fields are optional; firstname/lastname/login are derived from the email if omitted.
[customers]
# "john@example.com" = { firstname = "John", lastname = "Doe", login = "john", organization = "Acme Corp" }
# "jane@example.com" = {}

# Map every Redmine status name to a Zammad state type.
# The migration picks the first existing Zammad state whose state_type matches zammad_type.
# If a status is missing from this table, or its zammad_type has no matching Zammad state,
# the ticket falls back to "pending reminder" with pending_time = created_on (and a warning).
# If a Redmine issue has a due_date it always maps to "pending reminder" with pending_time = due_date,
# regardless of this table.
# The original Redmine status is always stored as a custom field ("Redmine Status") on each ticket.
[states]
"New"           = { zammad_type = "new" }
"In Progress"   = { zammad_type = "open" }
"Feedback"      = { zammad_type = "pending reminder" }
"Resolved"      = { zammad_type = "closed" }
"Closed"        = { zammad_type = "closed" }
"Rejected"      = { zammad_type = "closed" }

# Map every Redmine priority name to a Zammad priority.
# Valid zammad_priority values: "1 low", "2 normal", "3 high"
[priorities]
"Low"    = "1 low"
"Normal" = "2 normal"
"High"   = "3 high"
"Urgent" = "3 high"
